import java.util.*;

class Solution
{
    public static int solve(String s, char c, int n)
    {
        for(int i = 0; i < n; i++) {
            if(s.charAt(i) == c) {
                return i + 1; // 1-based indexing
            }
        }
        return -1;
    }
}
public class Main {
    public static void main(String[] args) throws Throwable {
        Scanner sc = new Scanner(System.in);
        int n=sc.nextInt();
        String s = sc.next();
        char c = sc.next().charAt(0);
        System.out.println(Solution.solve(s,c,n));
        return ;
    }
}
