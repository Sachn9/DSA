import java.util.Scanner;

public class Main
{
    public static void main(String[] args)
    {
        Scanner console = new Scanner(System.in);
        
        int number = console.nextInt();
        // write code here
        double sum = 0;

        for(int i = 1; i <= number; i++){
            sum = sum + (1.0 / i);
        }

        System.out.printf("%.5f", sum);
    }  
}
